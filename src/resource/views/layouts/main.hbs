<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        /* Cấu hình chung cho toàn bộ trang */
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            min-height: 100vh;
            scroll-behavior: smooth;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* Nền chuyển động mượt mà (Gradient Animation) */
        body {
            position: relative;
            overflow-x: hidden;
            background: linear-gradient(135deg, #e5e6e7 0%, #edeaf0 25%, #e0d9e0 50%, #d7dde2 75%, #e6ecec 100%);
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
            will-change: background-position;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Lớp phủ ánh sáng (Radial Glow Layer) */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.12), transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(255, 255, 255, 0.08), transparent 50%);
            pointer-events: none;
            z-index: 0;
        }

        /* Đảm bảo nội dung nổi lên trên lớp nền */
        .app {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Giúp footer luôn nằm dưới cùng ngay cả khi ít nội dung */
        .container {
            flex: 1;
            padding-top: 2rem;
            padding-bottom: 2rem;
        }
    </style>
</head>
<body>

    <div class="app">
        {{> header}}

        <main>
            {{{body}}}
        </main>

        {{> footer}}
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>