{
  "name": "blog",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "nodemon --inspect --watch src/index.js",
    "test":"node src/index.js",
    "watch": "sass -w src/resource/scss/:src/public/css/",
    "seed": "node src/config/seed.js",
    "killport": " netstat -ano | findstr :3000 ",
    "kill": "npx kill-port 3000"
  },
  "dependencies": {
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "express": "~4.16.1",
    "hbs": "^4.2.1",
    "http-errors": "~1.6.3",
    "jade": "~1.11.0",
    "method-override": "^3.0.0",
    "mongoose": "^9.7.1",
    "mongoose-delete": "^1.0.7",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "express-handlebars": "^9.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "morgan": "^1.11.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "sass": "^1.101.0"
  },
  "lint-staged": {
    "src/**/*.{js,json}": "prettier --tab-width 4 --write --single-quote --trailing-comma all"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
